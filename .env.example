APP_PORT=8080
POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/async_import?sslmode=disable
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_QUEUE=client_import_queue
RABBITMQ_RETRY_QUEUE=client_import_queue.retry
RABBITMQ_DLQ_QUEUE=client_import_queue.dlq
RABBITMQ_MAX_RETRIES=3
RABBITMQ_RETRY_DELAY_MS=5000
LOG_LEVEL=info
